soft":{"language":"python","language_group":"synapse_pyspark"}},"source":["# 1. Define the conditions (thresholds from your photo)\n","# 2. Define the corresponding category names\n","# 3. Create the new column\n","df = df.withColumn(\n","    'impact_category',\n","    F.when(F.col('gaming_impact_score') <= 30, 'Low')\n","     .when((F.col('gaming_impact_score') > 30) & (F.col('gaming_impact_score') <= 60), 'Moderate')\n","     .when(F.col('gaming_impact_score') > 60, 'High')\n","     .otherwise('Unknown')\n",")\n","\n","# Configure Spark settings to avoid rounding errors\n","try:\n","    spark.conf.set(\"spark.advise.divisionExprConvertRule.enable\", \"true\")\n","except NameError:\n","    pass\n","\n","# --- Verification & Summary ---\n","impact_summary = df.groupBy('impact_category').count().collect()\n","total_users = df.count()\n","\n","print(\"--- Gaming Impact Distribution ---\")\n","for row in impact_summary:\n","    print(f\"{row['impact_category']}: {row['count']} users\")\n","\n","# Calculate percentages for your report\n","print(\"\\n--- Percentage Distribution ---\")\n","for row in impact_summary:\n","    if total_users > 0:\n","        percentage = (row['count'] / total_users) * 100\n","        print(f\"{row['impact_category']}: {percentage:.2f}%\")\n","    else:\n","        print(f\"{row['impact_category']}: 0.00%\")"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":46,"statement_ids":[46],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state":"finished","queued_time":"2026-05-02T15:45:09.0355422Z","session_start_time":null,"execution_start_time":"2026-05-02T15:45:31.9088665Z","execution_finish_time":"2026-05-02T15:45:36.2588318Z","parent_msg_id":"d97aa85f-53f6-4fe8-9d69-502f1981b3a4"},"text/plain":"StatementMeta(, 90e7dceb-d467-4cb0-ab5b-b6aa2664561d, 46, Finished, Available, Finished, False)"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["--- Gaming Impact Distribution ---\nHigh: 2313 users\nLow: 100049 users\nModerate: 897638 users\n\n--- Percentage Distribution ---\nHigh: 0.23%\nLow: 10.00%\nModerate: 89.76%\n"]}],"execution_count":43},{"id":"c037d43c-c5d3-4050-ac4c-d3d4680be1b0","cell_type":"markdown","metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"},"nteract":{"transient":{"deleting":false}}},"source":["**\"Balanced Gamer\":**\n","A user must meet four healthy criteria simultaneously:\n","\n","  1- Moderate Play: Not excessive gaming (e.g.,< 4 hours/day).\n","\n","  2- Healthy Sleep: Getting enough rest (e.g., >/= 7 hours).\n","\n","  3 - Physical Activity: Engaging in exercise (e.g., >/= 1 hour).\n","  \n","  4-Social Connection: Maintaining a high social interaction score (e.g., > 5/10)."]},{"id":"343bdd82-e026-4d6d-8c34-0655245a0c98","cell_type":"code","metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"source":["# 1. Define the \"Healthy Thresholds\" based on your dataset averages\n","max_gaming_hours = 4\n","min_sleep_hours = 7\n","min_exercise_hours = 1\n","min_social_score = 5\n","\n","# 2 & 3. Identify the \"Balanced Gamers\" by applying all conditions as a boolean column\n","df = df.withColumn(\n","    'is_balanced_gamer',\n","    (F.col('daily_gaming_hours') <= max_gaming_hours) &\n","    (F.col('sleep_hours') >= min_sleep_hours) &\n","    (F.col('exercise_hours') >= min_exercise_hours) &\n","    (F.col('social_interaction_score') >= min_social_score)\n",")\n","\n","# 4. Calculate the KPI Percentage\n","total_users = df.count()\n","balanced_gamer_count = df.filter(F.col('is_balanced_gamer') == True).count()\n","balanced_gamer_percent = (balanced_gamer_count / total_users) * 100 if total_users > 0 else 0\n","\n","print(f\"--- Positive KPI: Balanced Gamer Score ---\")\n","print(f\"Total Users: {total_users:,}\")\n","print(f\"Number of Balanced Gamers: {balanced_gamer_count:,}\")\n","print(f\"Balanced Gamer Score: {balanced_gamer_percent:.2f}%\")"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":47,"statement_ids":[47],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state":"finished","queued_time":"2026-05-02T15:45:09.4599781Z","session_start_time":null,"execution_start_time":"2026-05-02T15:45:36.2612465Z","execution_finish_time":"2026-05-02T15:45:38.381381Z","parent_msg_id":"89079bb2-85e6-43d6-abe5-ad6754859a89"},"text/plain":"StatementMeta(, 90e7dceb-d467-4cb0-ab5b-b6aa2664561d, 47, Finished, Available, Finished, False)"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["--- Positive KPI: Balanced Gamer Score ---\nTotal Users: 1,000,000\nNumber of Balanced Gamers: 125,311\nBalanced Gamer Score: 12.53%\n"]}],"execution_count":44},{"id":"b75228cf-d65b-476b-8da7-1d547eb34323","cell_type":"markdown","metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"},"nteract":{"transient":{"deleting":false}}},"source":["**Adding User_ID column**"]},{"id":"77481c11-fab7-4b8e-82a7-ce3a236f0c69","cell_type":"code","metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"source":["from pyspark.sql.window import Window\n","\n","# Add User_ID starting from 1\n","windowSpec = Window.orderBy(F.monotonically_increasing_id())\n","df = df.withColumn(\"User_ID\", F.row_number().over(windowSpec))\n","\n","# Show Result\n","df.select('User_ID', 'mental_health_risk_index', 'gaming_impact_score').show(5)"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":48,"statement_ids":[48],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state