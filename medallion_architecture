  count = row['count']\n","    percentage = (count / total_users) * 100\n","    risk_dict[level] = {'count': count, 'percent': percentage}\n","\n","for level in ['Low Risk', 'Moderate Risk', 'High Risk']:\n","    if level in risk_dict:\n","        print(f\"{level}: {risk_dict[level]['percent']:.2f}% ({risk_dict[level]['count']:,} users)\")\n","\n","# 4. Quick Visualization for your report\n","# We collect the data to Pandas to use Seaborn/Matplotlib as usual\n","df_pd = df.select('Risk_Level').toPandas()\n","\n","plt.figure(figsize=(10, 6))\n","sns.countplot(data=df_pd, x='Risk_Level', palette='viridis', order=['Low Risk', 'Moderate Risk', 'High Risk'])\n","plt.title('Distribution of Mental Health Risk Levels')\n","plt.ylabel('Number of Gamers')\n","plt.show()"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":43,"statement_ids":[43],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state":"finished","queued_time":"2026-05-02T15:45:08.1632396Z","session_start_time":null,"execution_start_time":"2026-05-02T15:45:18.6408902Z","execution_finish_time":"2026-05-02T15:45:24.3754165Z","parent_msg_id":"0d8a79b9-7e73-4e76-99b3-bb56ab92dab2"},"text/plain":"StatementMeta(, 90e7dceb-d467-4cb0-ab5b-b6aa2664561d, 43, Finished, Available, Finished, False)"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["--- Risk Level Distribution ---\nLow Risk: 16.15% (161,499 users)\nModerate Risk: 67.72% (677,165 users)\nHigh Risk: 16.13% (161,336 users)\n"]},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x600 with 1 Axes>","image/png":""},"metadata":{}}],"execution_count":40},{"id":"8addb26d-aa40-4729-b858-41307a8c0b4f","cell_type":"markdown","metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"},"nteract":{"transient":{"deleting":false}}},"source":["**Average Stress Level:**\n","\n","this average against the Mental Health Risk Index, to see if stress is the primary driver of risk.\n","If the average is above 5, the community is leaning toward a high-stress environment.\n","If the average is below 5, gaming may be serving as a successful stress-relief mechanism for the majority."]},{"id":"1961414c-17b1-45c0-9594-45d94b8eefcd","cell_type":"code","metadata":{"microsoft":{"language":"python","language_group":"synapse_pyspark"}},"source":["# 1. Calculate the Global Average Stress Level\n","avg_stress = df.select(F.mean('stress_level')).collect()[0][0]\n","\n","# 2. Compare Stress: Balanced Gamers vs. High Risk Gamers\n","# This adds \"Depth\" to your KPI for the presentation\n","stress_comparison = df.groupBy('Risk_Level').agg(F.mean('stress_level').alias('mean_stress')).collect()\n","\n","# 3. Print the Results\n","print(f\"--- Psychological KPI: Average Stress Level ---\")\n","print(f\"Global Community Average: {avg_stress:.2f} / 10\")\n","print(\"\\n--- Stress Level by Risk Category ---\")\n","for row in stress_comparison:\n","    print(f\"{row['Risk_Level']}: {row['mean_stress']:.4f}\")\n","\n","# 4. Visualize for your \"Psychological Health\" Dashboard Page\n","df_pd = df.select('Risk_Level', 'stress_level').toPandas()\n","\n","plt.figure(figsize=(8, 5))\n","sns.boxplot(x='Risk_Level', y='stress_level', data=df_pd, palette='magma')\n","plt.title('Stress Distribution Across Risk Segments')\n","plt.ylabel('Stress Level (1-10)')\n","plt.show()"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":44,"statement_ids":[44],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state":"finished","queued_time":"2026-05-02T15:45:09.032001Z","session_start_time":null,"execution_start_time":"2026-05-02T15:45:24.3779291Z","execution_finish_time":"2026-05-02T15:45:28.7186