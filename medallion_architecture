ts['work_productivity_min']) / (stats['work_productivity_max'] - stats['work_productivity_min']) * 100\n",")\n","\n","# 2. Invert columns where 'lower is worse'\n","# For Sleep and Productivity, a LOW number means a HIGH negative impact\n","df = df.withColumn('inv_sleep', 100 - F.col('scaled_sleep'))\n","df = df.withColumn('inv_prod', 100 - F.col('scaled_prod'))\n","\n","# 3. Scale columns where 'higher is worse'\n","df = df.withColumn(\n","    'gaming_scaled',\n","    (F.col('daily_gaming_hours') - stats['daily_gaming_hours_min']) / (stats['daily_gaming_hours_max'] - stats['daily_gaming_hours_min']) * 100\n",")\n","df = df.withColumn(\n","    'mental_scaled',\n","    (F.col('mental_health_risk_index') - stats['mental_health_risk_index_min']) / (stats['mental_health_risk_index_max'] - stats['mental_health_risk_index_min']) * 100\n",")\n","\n","# 4. Calculate the Final Gaming Impact Score\n","# This is the average of all four negative impacts\n","df = df.withColumn(\n","    'gaming_impact_score',\n","    (F.col('gaming_scaled') + F.col('mental_scaled') + F.col('inv_sleep') + F.col('inv_prod')) / 4\n",")\n","\n","# Drop intermediate columns to keep the DataFrame clean\n","df = df.drop('scaled_sleep', 'scaled_prod', 'gaming_scaled', 'mental_scaled', 'inv_sleep', 'inv_prod')\n","\n","print(\"--- Gaming Impact Score Created ---\")\n","df.select('gaming_impact_score').describe().show()\n","\n","# Show a sample of the results\n","print(\"\\nSample Results (First 5 users):\")\n","df.select('daily_gaming_hours', 'mental_health_risk_index', 'gaming_impact_score').show(5)"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":45,"statement_ids":[45],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state":"finished","queued_time":"2026-05-02T15:45:09.0336946Z","session_start_time":null,"execution_start_time":"2