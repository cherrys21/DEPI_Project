_to_index:\n","    m = stats[f\"{c}_mean\"]\n","    s = stats[f\"{c}_stddev\"]\n","    df = df.withColumn(f\"{c}_zscore\", (F.col(c) - m) / s)\n","\n","# 3. Create the Mental Health Risk Index\n","# We sum the Z-scores across the row and divide by 4\n","df = df.withColumn(\n","    'mental_health_risk_index', \n","    (F.col('stress_level_zscore') + \n","     F.col('anxiety_score_zscore') + \n","     F.col('depression_score_zscore') + \n","     F.col('loneliness_score_zscore')) / 4\n",")\n","\n","# Drop temporary z-score columns to keep the DataFrame clean\n","df = df.drop(*[f\"{c}_zscore\" for c in columns_to_index])\n","\n","# 4. View the results\n","print(\"Mental Health Risk Index created successfully!\")\n","df.select('stress_level', 'anxiety_score', 'depression_score', 'loneliness_score', 'mental_health_risk_index').show(5)\n","\n","# 5. Summarize the KPI\n","print(\"\\n--- KPI Summary ---\")\n","df.select('mental_health_risk_index').describe().show()"],"outputs":[{"output_type":"display_data","data":{"application/vnd.livy.statement-meta+json":{"spark_pool":null,"statement_id":42,"statement_ids":[42],"state":"finished","livy_statement_state":"available","spark_jobs_updating":false,"session_id":"90e7dceb-d467-4cb0-ab5b-b6aa2664561d","normalized_state":"finished","queued_time":"2026-05-02T15:45:08.1613108Z","session_start_time":null,"execution_start_time":"2026-05-02T15:45:15.4671254Z","execution_finish_time":"2026-05-02T15:45:18.6383542Z","parent_msg_id":"32fdf8c8-e9f9-4c4a-aeac-96c98355f343"},"text/plain":"StatementMeta(, 90e7dceb-d467-4cb0-ab5b-b6aa2664561d, 42, Finished, Available, Finished, False)"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Mental Health Risk Index created successfully!\n+------------+-------------+----------------+----------------+------------------------+\n|stress_level|anxiety_score|depression_score|loneliness_score|mental_health_risk_index|\n+------------+-------------+----------------+----------------+-------------